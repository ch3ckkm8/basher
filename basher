#!/usr/bin/env bash

# basher - a simple key-value store
# Usage:
#   source basher <varname> <value>   # set a variable (and export it)
#   source basher <varname>           # get a variable
#   source basher --list              # list all variables
#   source basher --delete <varname>  # delete a variable
#   source basher --clear             # clear all variables
#   source basher --load              # export all stored variables into current shell
#
# TIP: Add this to your ~/.bashrc for easy use:
#   alias basher='source /path/to/basher'

